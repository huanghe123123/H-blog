# =============================================================================
# .env.example — 密钥与密码模板
# 复制为 .env 后填入实际值，.env 已被 .gitignore 排除
# 优先级: .env > config.yml > 代码默认值
# =============================================================================

# ---------------------------------------------------------------------------
# Docker 镜像（国内网络可替换为镜像加速源）
# ---------------------------------------------------------------------------
POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12-slim
NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine

# ---------------------------------------------------------------------------
# 数据库连接（含密码，覆盖 config.yml 的 database 段）
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://blog:blog@postgres:5432/blog

# ---------------------------------------------------------------------------
# 站主用户 ID（对应 users 表的 id，拥有最高权限）
# ---------------------------------------------------------------------------
SITE_OWNER=1

# ---------------------------------------------------------------------------
# JWT 密钥（生产环境: openssl rand -hex 32）
# ---------------------------------------------------------------------------
SECRET_KEY=

# ---------------------------------------------------------------------------
# 邮箱 SMTP 凭据（QQ 邮箱用授权码，非登录密码）
# 不配置则需在 config.yml 中将 features.email_verification 设为 false
# ---------------------------------------------------------------------------
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ---------------------------------------------------------------------------
# GitHub OAuth
# ---------------------------------------------------------------------------
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# LLM API（AI Agent 功能使用，支持任意 OpenAI 兼容接口）
# ---------------------------------------------------------------------------
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# ---------------------------------------------------------------------------
# AI Agent 功能开关（设为 true 启用 POST /api/agent）
# ---------------------------------------------------------------------------
AGENT_ENABLED=false

# ---------------------------------------------------------------------------
# MCP API Keys（三级权限，供 MCP Server 调用时使用）
# ---------------------------------------------------------------------------
MCP_KEY_OWNER=sk-mcp-owner-xxxx
MCP_KEY_ADMIN=sk-mcp-admin-xxxx
MCP_KEY_USER=sk-mcp-user-xxxx

# ---------------------------------------------------------------------------
# 部署用 Docker Compose 变量（deploy/docker-compose.yml 使用）
# ---------------------------------------------------------------------------
POSTGRES_USER=blog
POSTGRES_PASSWORD=
POSTGRES_DB=blog
BACKEND_IMAGE=blog-backend:latest
